// SERVER ENDPOINTS
// =====================================================
bool ex(const String& b, const char* k, float &v) {
  int i=b.indexOf(k); if(i<0)return false; int c=b.indexOf(':',i); if(c<0)return false;
  int e=b.indexOf(',',c); if(e<0)e=b.indexOf('}',c); if(e<0)return false;
  v=b.substring(c+1,e).toFloat(); return true;
}
void handleCmd() {
  String b=server.arg("plain"); float v;
  if(ex(b,"\"t\"",v)) baseThrottleUs=constrain((int)v,1000,2000);
  if(ex(b,"\"s\"",v)) stabilizeEnabled=(v>0.5);
  if(ex(b,"\"cr\"",v)) inputRoll=constrain(v, -1.0, 1.0);
  if(ex(b,"\"cp\"",v)) inputPitch=constrain(v, -1.0, 1.0);
  if(ex(b,"\"cy\"",v)) inputYaw=constrain(v, -1.0, 1.0);

  if(ex(b,"\"ap\"",v)) { Kp_angle_roll=v; Kp_angle_pitch=v; }
  if(ex(b,"\"rp\"",v)) { Kp_rate_roll=v; Kp_rate_pitch=v; }
  if(ex(b,"\"ri\"",v)) { Ki_rate_roll=v; Ki_rate_pitch=v; }
  if(ex(b,"\"rd\"",v)) { Kd_rate_roll=v; Kd_rate_pitch=v; }
  if(ex(b,"\"yp\"",v)) { Kp_rate_yaw=v; }
  if(ex(b,"\"yi\"",v)) { Ki_rate_yaw=v; }

  if(ex(b,"\"tm1\"",v)) { trimM1 = (int)v; }
  if(ex(b,"\"tm2\"",v)) { trimM2 = (int)v; }
  if(ex(b,"\"tm3\"",v)) { trimM3 = (int)v; }
  if(ex(b,"\"tm4\"",v)) { trimM4 = (int)v; }
  
  lastCmdMs=millis(); server.send(200,"text/plain","OK");
}

void handleStatus() {
  String j="{"; j+="\"armed\":"+String(armed?"1":"0");
  j+=",\"throttle\":"+String(baseThrottleUs);
  j+=",\"m1\":"+String(dbg_m1); j+=",\"m2\":"+String(dbg_m2); j+=",\"m3\":"+String(dbg_m3); j+=",\"m4\":"+String(dbg_m4);
  j+="}"; server.send(200,"application/json",j);
}

// =====================================================
// SETUP & BOOT SEQUENCE
// =====================================================
void setup() {
  Serial.begin(115200);
  Serial.println("\n\n=== BOOTING V75 (FINAL) ===");

  Wire.begin(SDA_PIN, SCL_PIN); 
  Wire.setClock(I2C_HZ);

  if(!configureLSM()) { Serial.println("LSM9DS1 Fail"); while(1) delay(100); }
 
  Serial.println("Calibrating IMU...");
  calibrateIMU();

  if(!setupEscPwm()) { Serial.println("PWM Init Fail"); while(1) delay(100); }
  setAll(1000);

  WiFi.mode(WIFI_STA);
  WiFi.begin(SSID, PASS);
  Serial.print("Connecting WiFi");
  while(WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\nIP: " + WiFi.localIP().toString());

  server.on("/", [](){server.send(200,"text/html",makeUI());});
  server.on("/status", handleStatus);
  server.on("/cmd", HTTP_POST, handleCmd);
  
  server.on("/autotrim", HTTP_POST, [](){
    if(!armed) { server.send(400, "text/plain", "Must be ARMED"); return; }
    
    // AutoTrim perfectly matched to V72 Mixer
    trimM1 += (int)(-dbg_rollCorr - dbg_pitchCorr);
    trimM2 += (int)( dbg_rollCorr - dbg_pitchCorr);
    trimM3 += (int)( dbg_rollCorr + dbg_pitchCorr);
    trimM4 += (int)(-dbg_rollCorr + dbg_pitchCorr);
    
    i_rRate=0; i_pRate=0; i_yRate=0; 
    
    String j="{\"tm1\":"; j+=trimM1; j+=",\"tm2\":"; j+=trimM2;
    j+=",\"tm3\":"; j+=trimM3; j+=",\"tm4\":"; j+=trimM4; j+="}";
    server.send(200, "application/json", j);
  });
  
  server.on("/arm", [](){
    float absR = abs((roll-accelRefRoll)*180/PI);
    float absP = abs((pitch-accelRefPitch)*180/PI);
    if(baseThrottleUs>1050 || absR>MAX_ARM_ANGLE || absP>MAX_ARM_ANGLE) {
      server.send(400,"text/plain","NO"); return;
    }
    armed=true; i_rRate=0; i_pRate=0; i_yRate=0; lastCmdMs=millis();
    server.send(200,"text/plain","OK");
  });
  server.on("/disarm", [](){ armed=false; baseThrottleUs=1000; server.send(200,"text/plain","OK"); });
  server.on("/kill", [](){ armed=false; baseThrottleUs=1000; server.send(200,"text/plain","OK"); });
  server.begin();
 
  // Launch the WebTask onto Core 0. By default, the Arduino loop() runs on Core 1.
  xTaskCreatePinnedToCore(webTaskCode, "WebTask", 10000, NULL, 1, &WebTask, 0);

  Serial.println("Ready 250Hz - Physics on Core 1, Web on Core 0");
}

void loop() {
  // Runs exclusively on Core 1
  controlLoopTick();
  yield(); // Feeds the watchdog timer to prevent ESP32 reboots
}

