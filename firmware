const int ESC_MAX_US = 2000;  // 2000us = 100% throttle

// Converts microseconds (1000-2000) to the 14-bit duty cycle required by the ESP32 hardware timer.
static inline uint32_t usToDuty(int us) {
  us = constrain(us, ESC_MIN_US, ESC_MAX_US);
  return (uint32_t)((us * 16383UL) / 20000UL);
}

