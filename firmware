// Cascaded PID Setup: 
// Outer loop controls ANGLE (Target Angle - Current Angle = Desired Rate).
// Inner loop controls RATE (Desired Rate - Current Gyro Rate = Motor Output).
float Kp_angle_roll=4.0f, Kp_angle_pitch=4.0f;
float Kp_rate_roll=0.20f, Ki_rate_roll=0.05f, Kd_rate_roll=0.0f;
