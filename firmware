// Limits how much of the motor bandwidth the PID is allowed to command.
// Prevents a hard roll from saturating the motors and causing a loss of throttle/altitude.
const float ROLL_CORR_LIMIT_US=300.0f, PITCH_CORR_LIMIT_US=300.0f, YAW_CORR_LIMIT_US=200.0f;

