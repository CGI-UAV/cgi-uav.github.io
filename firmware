// GYRO SMOOTHING FILTER VARIABLES
// An Exponential Moving Average (EMA) low-pass filter. 
// Formula: NewVal = (OldVal * (1 - Alpha)) + (RawVal * Alpha)
// This smooths out motor vibrations so the PID D-term doesn't amplify the noise.
float prevGyrX = 0, prevGyrY = 0, prevGyrZ = 0;
const float GYRO_FILTER_ALPHA = 0.3f; // Lower = smoother but more delay/lag.

