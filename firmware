// Reads the IMU multiple times and averages the result to act as a rudimentary 
// hardware-level low-pass filter against propeller vibrations.
bool imuReadAveraged(ImuSample &out) {
  float sax=0, say=0, saz=0, sgx=0, sgy=0, sgz=0;
  int ok=0; sensors_event_t a, m, g, temp;
  for (int i=0; i<READ_AVG_N; i++) {
     lsm.getEvent(&a, &m, &g, &temp);
     sax += a.acceleration.x; say += a.acceleration.y; saz += a.acceleration.z;
     sgx += g.gyro.x; sgy += g.gyro.y; sgz += g.gyro.z;
     ok++;
  }
  if (ok==0) return false;
  out.ax = sax/ok; out.ay = say/ok; out.az = saz/ok;
  out.gx = sgx/ok; out.gy = sgy/ok; out.gz = sgz/ok;
  return true;
}

// Uses Trigonometry to convert raw 3D acceleration vectors into 2D Euler angles (Roll/Pitch).
void accelToAngles(float ax, float ay, float az, float &R, float &P) {
  if (az == 0.0f && ax == 0.0f && ay == 0.0f) { R=0; P=0; return; }
  R = atan2(ay, az); 
  P = atan2(-ax, sqrt(ay*ay+az*az));
}

bool configureLSM() {
  if (!lsm.begin()) return false;
  lsm.setupAccel(lsm.LSM9DS1_ACCELRANGE_4G);   // 4G covers drone bumps without clipping
  lsm.setupGyro(lsm.LSM9DS1_GYROSCALE_500DPS); // 500 Deg/Sec is enough for stabilized flight
  lsm.setupMag(lsm.LSM9DS1_MAGGAIN_4GAUSS);
  return true;
}

// Samples the IMU 500 times on boot to find the "zero" point for the gyros (which naturally drift)
// and establishes the level attitude based on the surface it booted on.
void calibrateIMU() {
  double sgx=0,sgy=0,sgz=0, sax=0,say=0,saz=0; int ok=0; ImuSample s;
  Serial.println("Keep drone stationary..."); delay(1000);
  for (int i=0; i<500; i++) {
    if (imuReadAveraged(s)) {
      sgx += s.gx; sgy += s.gy; sgz += s.gz;
      sax += s.ax; say += s.ay; saz += s.az; ok++;
    }
    delay(2);
  }
  if (ok==0) { Serial.println("Fail"); while(1); }
  
  // Calculate average bias/error
  gyroBiasX=sgx/ok; gyroBiasY=sgy/ok; gyroBiasZ=sgz/ok;
  float initAx = sax/ok; float initAy = say/ok; float initAz = saz/ok;
  
  float ar, ap; accelToAngles(initAx, initAy, initAz, ar, ap);
  accelRefRoll=ar; accelRefPitch=ap; roll=ar; pitch=ap;
}

bool setupEscPwm() {
  if(!ledcAttach(M1_PIN, ESC_FREQ, ESC_RES_BITS)) return false;
  if(!ledcAttach(M2_PIN, ESC_FREQ, ESC_RES_BITS)) return false;
  if(!ledcAttach(M3_PIN, ESC_FREQ, ESC_RES_BITS)) return false;
  if(!ledcAttach(M4_PIN, ESC_FREQ, ESC_RES_BITS)) return false;
  return true;
}

void writeEsc(int pin, int us) { ledcWrite(pin, usToDuty(us)); }

void setAll(int us) { 
  writeEsc(M1_PIN, us); writeEsc(M2_PIN, us); writeEsc(M3_PIN, us); writeEsc(M4_PIN, us); 
  dbg_m1=us; dbg_m2=us; dbg_m3=us; dbg_m4=us; 
}

// =====================================================
// PID CONTROL MATH
// =====================================================
// The core algorithm keeping the drone in the air.
// Proportional (P): Corrects current error. (Pushes back proportionally to how far it tilted).
// Integral (I): Corrects past error. (Winds up over time to fix steady imbalances, like a heavy battery).
// Derivative (D): Predicts future error. (Dampens the P-term to stop overshoot and bouncing).
float pidRate(float tgt, float meas, float &i, float &le, float kp, float ki, float kd, float dt) {
  float err = tgt - meas;
  
  // Accumulate I-term over time (Error * DeltaTime)
  i += err * dt; 
  
  // Anti-Windup constraint: Prevents the I-term from growing infinitely if the drone gets stuck
  i = constrain(i, -400.0f, 400.0f); 
  
  // Calculate slope of the error for the D-term (Change in Error / DeltaTime)
  float d = (err - le) / dt; 
  le = err;
  
  return (kp * err) + (ki * i) + (kd * d);
}

// Ramping array prevents instant 0-100% throttle spikes from frying the ESCs
int rampUs[4] = {1000,1000,1000,1000};
const float RAMP_SPD = 6000.0f; // Max microsecond change per second

// Main control loop - must run incredibly fast and without interruption
void controlLoopTick() {
  unsigned long now = micros();
  // Enforce precise loop timing (250Hz)
  if (now - lastControlMicros < CONTROL_DT_US) return;
  float dt = (now - lastControlMicros)/1000000.0f; lastControlMicros=now;

  // Failsafe: If the loop lagged heavily (e.g., WiFi blocked it), reset dt to prevent 
  // massive math spikes in the PID integrals.
  if (dt > 0.015f) dt = 0.004f; 

  ImuSample s;
  if(imuReadAveraged(s)) {
     // 1. Subtract the zero-bias calibrated at boot
     float accX = s.ax; float accY = s.ay; float accZ = s.az;
     float rawGyrX = s.gx - gyroBiasX; float rawGyrY = s.gy - gyroBiasY; float rawGyrZ = s.gz - gyroBiasZ;

     // 2. Apply Software Low-Pass Filter to Gyros
     float gyrX = (prevGyrX * (1.0f - GYRO_FILTER_ALPHA)) + (rawGyrX * GYRO_FILTER_ALPHA);
     float gyrY = (prevGyrY * (1.0f - GYRO_FILTER_ALPHA)) + (rawGyrY * GYRO_FILTER_ALPHA);
     float gyrZ = (prevGyrZ * (1.0f - GYRO_FILTER_ALPHA)) + (rawGyrZ * GYRO_FILTER_ALPHA);
     prevGyrX = gyrX; prevGyrY = gyrY; prevGyrZ = gyrZ;

     dbg_rawGyrX = rawGyrX * 180.0f/PI;
     dbg_gyrX = gyrX * 180.0f/PI;

     // Convert to user-friendly degrees per second for PID tuning
     rollRateDps = gyrX*180.0f/PI; pitchRateDps = gyrY*180.0f/PI; yawRateDps = gyrZ*180.0f/PI;
     
     // Deadband filter: Ignore tiny yaw drifts so the drone doesn't constantly spin slightly
     if (abs(yawRateDps) < 1.5f) { yawRateDps = 0.0f; }
     
     // 3. Complementary Filter: Fuse raw Accelerometer vectors with Gyro rates
     float ar, ap; accelToAngles(accX, accY, accZ, ar, ap);
     roll = ALPHA*(roll + gyrX*dt) + (1.0f-ALPHA)*ar;
     pitch = ALPHA*(pitch + gyrY*dt) + (1.0f-ALPHA)*ap;
  }

  // Safety Cutoff Check
  if (armed && (millis()-lastCmdMs > CMD_TIMEOUT_MS)) {
    armed=false; baseThrottleUs=1000; inputRoll=0; inputPitch=0; inputYaw=0;
    Serial.println("Failsafe Timeout");
  }

  if (!armed) { 
    setAll(1000); 
    for(int i=0;i<4;i++) rampUs[i]=1000; 
  } else {
    // Convert absolute angles to degrees and find deviation from level
    float rd = (roll-accelRefRoll)*180.0f/PI; float pd = (pitch-accelRefPitch)*180.0f/PI;
   
    // Map pilot input to physical target angles
    // INVERTED TARGETS (Locked from V72)
    float targetR = (-inputRoll  * MAX_PITCH_ROLL_ANGLE) + trimRoll;
    float targetP = (-inputPitch * MAX_PITCH_ROLL_ANGLE) + trimPitch;
    float targetYRate = (-inputYaw * MAX_YAW_RATE_DPS) + trimYaw;

    dbg_targetP = targetP;
    dbg_pd = pd;

    // OUTER LOOP: Calculate desired angular rate to achieve the target angle
    float rrT = Kp_angle_roll * ((targetR+trimRollDeg)-rd);
    float prT = Kp_angle_pitch * ((targetP+trimPitchDeg)-pd);
    rrT = constrain(rrT, -200, 200); prT = constrain(prT, -200, 200);

    float rc=0, pc=0, yc=0;
   
    // Zero out the Integral memory if throttle is low, otherwise it will "wind up" 
    // trying to correct errors while sitting on the ground, causing it to flip on takeoff.
    if (baseThrottleUs < 1050) { i_rRate = 0; i_pRate = 0; i_yRate = 0; }

    // INNER LOOP: Generate the microsecond correction pulses using the Gyro rates
    rc = pidRate(rrT, rollRateDps, i_rRate, lastErrRRate, Kp_rate_roll, Ki_rate_roll, Kd_rate_roll, dt);
    pc = pidRate(prT, pitchRateDps, i_pRate, lastErrPRate, Kp_rate_pitch, Ki_rate_pitch, Kd_rate_pitch, dt);
    yc = pidRate(targetYRate, yawRateDps, i_yRate, lastErrYRate, Kp_rate_yaw, Ki_rate_yaw, Kd_rate_yaw, dt);
    
    // Constrain the PID outputs so they don't overpower the base throttle
    rc = constrain(rc, -ROLL_CORR_LIMIT_US, ROLL_CORR_LIMIT_US);
    pc = constrain(pc, -PITCH_CORR_LIMIT_US, PITCH_CORR_LIMIT_US);
    yc = constrain(yc, -YAW_CORR_LIMIT_US, YAW_CORR_LIMIT_US);
   
    dbg_rollCorr=rc; dbg_pitchCorr=pc;

    // =====================================================
    // DYNAMIC MIXING MATRIX
    // =====================================================
    // Converts the 3 abstract physical axes (Roll, Pitch, Yaw) into 4 specific motor speeds.
    // E.g., To pitch forward, M3 and M4 (Rear) speed up (+pc), M1 and M2 (Front) slow down (-pc).
    int m1 = baseThrottleUs - rc - pc + yc + trimM1; // Front Left  (Spins CW)
    int m2 = baseThrottleUs + rc - pc - yc + trimM2; // Front Right (Spins CCW)
    int m3 = baseThrottleUs + rc + pc + yc + trimM3; // Rear Right  (Spins CW)
    int m4 = baseThrottleUs - rc + pc - yc + trimM4; // Rear Left   (Spins CCW)
   
    int t[4]={constrain(m1,1000,2000), constrain(m2,1000,2000), constrain(m3,1000,2000), constrain(m4,1000,2000)};

    // Motor Ramping (Soft Start logic)
    float step = RAMP_SPD * dt;
    for(int i=0;i<4;i++) {
      int d = t[i] - rampUs[i];
      if (abs(d) <= step) rampUs[i] = t[i];
      else rampUs[i] += (d>0 ? step : -step);
      
      if(i==0) writeEsc(M1_PIN, rampUs[i]);
      if(i==1) writeEsc(M2_PIN, rampUs[i]);
      if(i==2) writeEsc(M3_PIN, rampUs[i]);
      if(i==3) writeEsc(M4_PIN, rampUs[i]);
    }
    dbg_m1=rampUs[0]; dbg_m2=rampUs[1]; dbg_m3=rampUs[2]; dbg_m4=rampUs[3];
  }

  // =====================================================
  // CSV DATA LOGGING (50Hz to prevent Serial bottleneck)
  // =====================================================
  if(millis() - lastDebugMs > 20) {
    lastDebugMs = millis();
    
    if (LOGGING_MODE == 0) {
      Serial.printf("R:%.1f P:%.1f TrimP:%.1f TrimY:%.1f dt:%.4f\n",
         (roll-accelRefRoll)*180/PI, (pitch-accelRefPitch)*180/PI, trimPitch, trimYaw, dt);
    } 
    else if (LOGGING_MODE == 1) {
      Serial.printf("%lu,%.2f,%.2f\n", millis(), dbg_rawGyrX, dbg_gyrX);
    }
    else if (LOGGING_MODE == 2) {
      if (armed) Serial.printf("%lu,%.2f,%.2f\n", millis(), dbg_targetP, dbg_pd);
    }
    else if (LOGGING_MODE == 3) {
      Serial.printf("%lu,%.5f\n", millis(), dt);
    }
  }
}

// =====================================================
// WEB SERVER TASK (CORE 0)
// =====================================================
// Because the ESP32 is dual-core, we pin the WebServer and WiFi stack to Core 0.
// This ensures that rendering the HTML and handling HTTP POST packets never interrupts
// the controlLoopTick() running on Core 1.
void webTaskCode(void * parameter) {
  for(;;) {
    server.handleClient();
    vTaskDelay(2 / portTICK_PERIOD_MS); // Yield to the FreeRTOS watchdog
  }
}

