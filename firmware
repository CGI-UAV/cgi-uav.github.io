// Complementary Filter Alpha. 
// 98.5% of the angle comes from integrating the Gyroscope (fast, but drifts over time).
// 1.5% of the angle comes from the Accelerometer (noisy from vibrations, but absolute to gravity).
const float ALPHA = 0.985f;
